<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/geminiSectionTitle"
            style="@style/TextAppearance.Sushi.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/gemini_settings_section_title" />

        <TextView
            android:id="@+id/settingsGeminiSubtitle"
            style="@style/TextAppearance.Sushi.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/gemini_settings_subtitle" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/geminiEnabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/gemini_settings_toggle" />

        <TextView
            android:id="@+id/geminiAuthStatusText"
            style="@style/TextAppearance.Sushi.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/apiKeyLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/gemini_api_key_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/apiKeyInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/apiKeyHelper"
            style="@style/TextAppearance.Sushi.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/gemini_api_key_helper" />

        <!-- ── Cloud model section ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="?attr/colorOutline" />

        <TextView
            android:id="@+id/geminiModelSectionTitle"
            style="@style/TextAppearance.Sushi.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/gemini_model_section_title" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/geminiModelToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/geminiModelFlash"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gemini_model_flash" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/geminiModelPro"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gemini_model_pro" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/geminiModelHelper"
            style="@style/TextAppearance.Sushi.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/gemini_model_helper" />

        <!-- ── On-device Nano section ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="?attr/colorOutline" />

        <TextView
            android:id="@+id/geminiNanoSectionTitle"
            style="@style/TextAppearance.Sushi.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/gemini_nano_section_title" />

        <TextView
            android:id="@+id/nanoStatusText"
            style="@style/TextAppearance.Sushi.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/gemini_nano_status_unavailable" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nanoDownloadButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/gemini_nano_download_button"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/nanoDownloadProgress"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:indeterminate="false"
            android:max="100"
            android:visibility="gone" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/nanoPreferredSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/gemini_nano_preferred_toggle" />

        <TextView
            android:id="@+id/nanoPreferredHelper"
            style="@style/TextAppearance.Sushi.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/gemini_nano_preferred_helper" />

    </LinearLayout>
</ScrollView>
