<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/playsPageTitleText"
        style="@style/TextAppearance.Sushi.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/plays_title"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/playsPageSubtitleText"
        style="@style/TextAppearance.Sushi.Caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/main_plays_subtitle" />

    <TextView
        android:id="@+id/playsEmptyStateText"
        style="@style/TextAppearance.Sushi.Caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/main_plays_empty_ready"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/playsEmptyActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addHostButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/action_add_host"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addPlayButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/action_add_play"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/playsButton"
        style="@style/Widget.Sushi.PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/action_plays"
        app:icon="@drawable/ic_play_arrow"
        app:iconGravity="textStart" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/managePlaysButton"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/action_manage_plays"
        app:icon="@drawable/ic_list"
        app:iconGravity="textStart" />

    <TextView
        android:id="@+id/sessionLogLabel"
        style="@style/TextAppearance.Sushi.Caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/session_log_label" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/copyLogButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:text="@string/action_copy_log"
            app:icon="@drawable/ic_content_copy"
            app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearLogButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:text="@string/action_clear_log"
            app:icon="@drawable/ic_clear"
            app:iconGravity="textStart" />
    </LinearLayout>

    <net.hlan.sushi.TerminalView
        android:id="@+id/sessionLogText"
        style="@style/TextAppearance.Sushi.Body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1"
        android:background="@color/sushi_terminal_bg"
        android:fontFamily="monospace"
        android:padding="12dp"
        android:text="@string/session_log_placeholder"
        android:textColor="@color/sushi_ink" />

</LinearLayout>
