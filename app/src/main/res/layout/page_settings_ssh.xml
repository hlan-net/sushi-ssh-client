<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/sshSectionTitle"
            style="@style/TextAppearance.Sushi.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ssh_section_title" />

        <TextView
            android:id="@+id/sshSectionSubtitle"
            style="@style/TextAppearance.Sushi.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/ssh_section_subtitle" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/settingsSummaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/sushi_white"
            app:cardElevation="1dp"
            app:strokeColor="@color/sushi_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/settingsSummaryTitle"
                    style="@style/TextAppearance.Sushi.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_summary_title"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/summaryHostLabel"
                        style="@style/TextAppearance.Sushi.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_summary_host_label" />

                    <TextView
                        android:id="@+id/summaryHostValue"
                        style="@style/TextAppearance.Sushi.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/settings_summary_host_none" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/summaryAuthLabel"
                        style="@style/TextAppearance.Sushi.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_summary_auth_label" />

                    <TextView
                        android:id="@+id/summaryAuthValue"
                        style="@style/TextAppearance.Sushi.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/settings_summary_auth_none" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/summaryGeminiLabel"
                        style="@style/TextAppearance.Sushi.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_summary_gemini_label" />

                    <TextView
                        android:id="@+id/summaryGeminiValue"
                        style="@style/TextAppearance.Sushi.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/settings_summary_gemini_disabled" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/summaryDriveLabel"
                        style="@style/TextAppearance.Sushi.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_summary_drive_label" />

                    <TextView
                        android:id="@+id/summaryDriveValue"
                        style="@style/TextAppearance.Sushi.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="@string/settings_summary_drive_signed_out" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testConnectionButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/action_test_connection" />

        <TextView
            android:id="@+id/testConnectionResultText"
            style="@style/TextAppearance.Sushi.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/test_connection_idle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/copyConnectionDiagnosticsButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/action_copy_connection_diagnostics"
            android:visibility="gone" />

        <TextView
            android:id="@+id/hostsKeysSectionTitle"
            style="@style/TextAppearance.Sushi.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/settings_hosts_keys_title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickAddHostButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/action_add_host" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quickGenerateKeyButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/action_generate_key_quick" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/manageHostsButton"
            style="@style/Widget.Sushi.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/action_hosts" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/manageKeysButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/action_keys_short" />

    </LinearLayout>
</ScrollView>
