<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/driveSectionTitle"
            style="@style/TextAppearance.Sushi.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/drive_section_title" />

        <TextView
            android:id="@+id/driveSectionSubtitle"
            style="@style/TextAppearance.Sushi.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/drive_section_subtitle" />

        <TextView
            android:id="@+id/driveStatusText"
            style="@style/TextAppearance.Sushi.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/drive_status_signed_out" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/driveSignInButton"
            style="@style/Widget.Sushi.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/action_drive_sign_in" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/driveSignOutButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/action_drive_sign_out"
            android:visibility="gone" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/driveAlwaysSaveSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/drive_always_save_toggle" />

        <TextView
            android:id="@+id/driveAlwaysSaveHelper"
            style="@style/TextAppearance.Sushi.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/drive_always_save_helper" />

    </LinearLayout>
</ScrollView>
