<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sushi_terminal_bg_dark"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/terminalStatusText"
        style="@style/TextAppearance.Sushi.Caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/terminal_status_disconnected"
        android:textColor="@color/sushi_terminal_text" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/terminalConnectButton"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/action_start_session"
        app:icon="@drawable/ic_terminal"
        app:iconGravity="textStart" />

    <LinearLayout
        android:id="@+id/terminalErrorBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="?attr/colorErrorContainer"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/terminalErrorBannerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnErrorContainer"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/terminalErrorBannerAction"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnErrorContainer"
                android:visibility="gone" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/terminalErrorBannerDismiss"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_dismiss"
                android:textColor="?attr/colorOnErrorContainer" />

        </LinearLayout>

    </LinearLayout>

    <net.hlan.sushi.TerminalView
        android:id="@+id/terminalOutputText"
        style="@style/TextAppearance.Sushi.Body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@color/sushi_terminal_panel_dark"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:fontFamily="monospace"
        android:padding="8dp"
        android:text="@string/session_log_placeholder"
        android:textColor="@color/sushi_terminal_text" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/terminalEnterButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/action_send_enter" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/terminalTabButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/action_send_tab" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/terminalBackspaceButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/action_send_backspace" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/terminalCtrlCButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/action_send_ctrl_c"
            android:textColor="?attr/colorError" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/terminalCtrlDButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/action_send_ctrl_d" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/terminalPasteButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/action_paste"
            app:icon="@drawable/ic_content_paste"
            app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/terminalPhrasesButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/action_phrases_short"
            app:icon="@drawable/ic_format_quote"
            app:iconGravity="textStart" />
    </LinearLayout>

</LinearLayout>
